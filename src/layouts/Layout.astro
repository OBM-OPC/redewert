---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Redewert Klaus Reinke',
  description = 'Freier Trauerredner Klaus Reinke. Durch Verlust, Trauer und Fassungslosigkeit begleite ich Sie als Trauerredner ins Neue. Gewinnen Sie Zuversicht.',
  ogImage = 'https://klausreinke.de/wp-content/uploads/2024/01/redewert_logotype_gruen-beige-1024x393.png'
} = Astro.props;

const canonicalUrl = 'https://klausreinke.de' + Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="de" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="follow, index" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:locale" content="de_DE" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Redewert - Klaus Reinke" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="800" />
  <meta property="og:image:height" content="307" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Icons -->
  <link rel="icon" href="/images/redewert_logo_gruen-1-1024x1024.png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/images/redewert_logo_gruen-1-1024x1024.png" />

  <!-- Fonts: preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": ["ProfessionalService", "Organization"],
        "@id": "https://klausreinke.de/#organization",
        "name": "Redewert - Klaus Reinke",
        "url": "https://klausreinke.de",
        "email": "redewert@klausreinke.de",
        "logo": {
          "@type": "ImageObject",
          "@id": "https://klausreinke.de/#logo",
          "url": "https://klausreinke.de/wp-content/uploads/2024/01/redewert_logotype_gruen-beige.png",
          "contentUrl": "https://klausreinke.de/wp-content/uploads/2024/01/redewert_logotype_gruen-beige.png",
          "caption": "Redewert - Klaus Reinke",
          "inLanguage": "de",
          "width": "5127",
          "height": "1967"
        },
        "image": {"@id": "https://klausreinke.de/#logo"}
      },
      {
        "@type": "WebSite",
        "@id": "https://klausreinke.de/#website",
        "url": "https://klausreinke.de",
        "name": "Redewert - Klaus Reinke",
        "alternateName": "Redewert",
        "publisher": {"@id": "https://klausreinke.de/#organization"},
        "inLanguage": "de"
      },
      {
        "@type": "AboutPage",
        "@id": "https://klausreinke.de/#webpage",
        "url": "https://klausreinke.de/",
        "name": "Redewert Klaus Reinke",
        "about": {"@id": "https://klausreinke.de/#organization"},
        "isPartOf": {"@id": "https://klausreinke.de/#website"},
        "inLanguage": "de"
      },
      {
        "@type": "Person",
        "name": "Redewert Klaus Reinke",
        "description": "Freier Trauerredner Klaus Reinke. Durch Verlust, Trauer und Fassungslosigkeit begleite ich Sie als Trauerredner ins Neue. Gewinnen Sie Zuversicht.",
        "email": "redewert@klausreinke.de",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Hölderlinstraße 12",
          "addressLocality": "Hemsbach",
          "postalCode": "69502",
          "addressCountry": "Deutschland"
        },
        "jobTitle": "Trauerredner",
        "@id": "https://klausreinke.de/#schema-10894"
      }
    ]
  }
  </script>

  <style>
    /* Inline critical styles for instant render */
    body {
      font-family: "IBM Plex Serif", Georgia, serif;
      background-color: #F2EEEB;
      color: #1C4003;
      margin: 0;
      padding: 2vw 2vw 0 0;
    }
  </style>
</head>
<body class="antialiased">
  <slot />
</body>
</html>
