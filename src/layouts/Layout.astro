---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Redewert Klaus Reinke',
  description = 'Freier Trauerredner Klaus Reinke. Durch Verlust, Trauer und Fassungslosigkeit begleite ich Sie als Trauerredner ins Neue. Gewinnen Sie Zuversicht.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="de" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="follow, index" />
  <link rel="canonical" href="https://klausreinke.de/" />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content="https://klausreinke.de/" />
  <meta property="og:site_name" content="Redewert - Klaus Reinke" />
  <meta property="og:image" content="https://klausreinke.de/wp-content/uploads/2024/01/redewert_logotype_gruen-beige-1024x393.png" />
  <meta property="og:image:width" content="800" />
  <meta property="og:image:height" content="307" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://klausreinke.de/wp-content/uploads/2024/01/redewert_logotype_gruen-beige-1024x393.png" />
  <link rel="icon" href="/images/redewert_logo_gruen-1-1024x1024.png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/images/redewert_logo_gruen-1-1024x1024.png" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": ["ProfessionalService", "Organization"],
        "@id": "https://klausreinke.de/#organization",
        "name": "Redewert - Klaus Reinke",
        "url": "https://klausreinke.de",
        "email": "redewert@klausreinke.de",
        "logo": {
          "@type": "ImageObject",
          "@id": "https://klausreinke.de/#logo",
          "url": "https://klausreinke.de/wp-content/uploads/2024/01/redewert_logotype_gruen-beige.png",
          "contentUrl": "https://klausreinke.de/wp-content/uploads/2024/01/redewert_logotype_gruen-beige.png",
          "caption": "Redewert - Klaus Reinke",
          "inLanguage": "de",
          "width": "5127",
          "height": "1967"
        },
        "image": {"@id": "https://klausreinke.de/#logo"}
      },
      {
        "@type": "WebSite",
        "@id": "https://klausreinke.de/#website",
        "url": "https://klausreinke.de",
        "name": "Redewert - Klaus Reinke",
        "alternateName": "Redewert",
        "publisher": {"@id": "https://klausreinke.de/#organization"},
        "inLanguage": "de"
      },
      {
        "@type": "AboutPage",
        "@id": "https://klausreinke.de/#webpage",
        "url": "https://klausreinke.de/",
        "name": "Redewert Klaus Reinke",
        "about": {"@id": "https://klausreinke.de/#organization"},
        "isPartOf": {"@id": "https://klausreinke.de/#website"},
        "inLanguage": "de"
      },
      {
        "@type": "Person",
        "name": "Redewert Klaus Reinke",
        "description": "Freier Trauerredner Klaus Reinke. Durch Verlust, Trauer und Fassungslosigkeit begleite ich Sie als Trauerredner ins Neue. Gewinnen Sie Zuversicht.",
        "email": "redewert@klausreinke.de",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Hölderlinstraße 12",
          "addressLocality": "Hemsbach",
          "postalCode": "69502",
          "addressCountry": "Deutschland"
        },
        "jobTitle": "Trauerredner",
        "@id": "https://klausreinke.de/#schema-10894"
      }
    ]
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600&family=IBM+Plex+Serif:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>
<body class="bg-[#F2EEEB] text-[#1C4003] font-body antialiased px-[2vw]">
  <div class="pt-[2vw]">
    <slot />
  </div>
</body>
</html>
