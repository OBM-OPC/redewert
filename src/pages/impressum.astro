---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Impressum – Klaus Reinke" description="Impressum von Redewert Klaus Reinke">
  <section class="bg-[#F2EEEB] text-[#1C4003] py-16 px-[4vw]">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-heading text-3xl md:text-4xl mb-8">Impressum</h1>

      <h2 class="font-heading text-xl mb-4">Angaben Gemäß §5 TMG</h2>
      <p class="font-body mb-2"><strong>Klaus Reinke</strong></p>
      <p class="font-body mb-2">Hölderlin Straße 12</p>
      <p class="font-body mb-6">69502 Hemsbach</p>

      <h2 class="font-heading text-xl mb-4">Kontakt</h2>
      <p class="font-body mb-2">Telefon: <a href="tel:+491709100541" class="underline">0170 9100541</a></p>
      <p class="font-body mb-6">E-Mail: <a href="mailto:redewert@klausreinke.de" class="underline">redewert@klausreinke.de</a></p>

      <h2 class="font-heading text-xl mb-4">Umsatzsteuer</h2>
      <p class="font-body">Kleingewerbe gemäß §19 UStG von der Umsatzsteuer befreit</p>
    </div>
  </section>
</Layout>
